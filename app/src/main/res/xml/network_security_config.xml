<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        Configuración de seguridad de red — AyudaMayor v3.2.37

        HTTPS obligatorio para el servidor de producción (mejoresiagratis.com).
        HTTP permitido SOLO en red local (IPs privadas RFC 1918) para los
        dispositivos IoT: Samsung TV (8001), Chromecast (8008), Livebox,
        Shelly, etc. El usuario puede tener cualquier subred (192.168.x.x,
        10.x.x.x, 172.16-31.x.x) dependiendo de su operadora.

        Nota técnica: las conexiones de control IoT desde Kotlin (SamsungTVController,
        IotDiscovery) usan Socket() directo y NO pasan por este config.
        Este config solo afecta a los fetch() del WebView JS.
    -->

    <!-- Servidor de producción: solo HTTPS, certificado del sistema -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">mejoresiagratis.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Red local RFC 1918 — 192.168.x.x (Orange, Movistar, Vodafone, Jazztel...) -->
    <domain-config cleartextTrafficPermitted="true">
