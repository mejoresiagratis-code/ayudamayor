<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Solo HTTPS en producción -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        Permitir HTTP cleartext en red local para IoT (Samsung TV puerto 8001,
        Chromecast 8008, Shelly, etc.).
        IMPORTANTE: Android no acepta rangos de subred en <domain>. Hay que listar
        cada IP individualmente. Las más habituales en redes domésticas españolas:
        router Orange Livebox (192.168.1.1), descodificador (192.168.1.10),
        Chromecast (192.168.1.11), Samsung TV (192.168.1.12).
        Añade aquí cualquier IP adicional que necesites.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Red 192.168.1.x — la más común en routers Orange/Movistar/Vodafone -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">192.168.1.3</domain>
        <domain includeSubdomains="false">192.168.1.4</domain>
        <domain includeSubdomains="false">192.168.1.5</domain>
        <domain includeSubdomains="false">192.168.1.6</domain>
        <domain includeSubdomains="false">192.168.1.7</domain>
        <domain includeSubdomains="false">192.168.1.8</domain>
        <domain includeSubdomains="false">192.168.1.9</domain>
        <domain includeSubdomains="false">192.168.1.10</domain>
        <domain includeSubdomains="false">192.168.1.11</domain>
        <domain includeSubdomains="false">192.168.1.12</domain>
        <domain includeSubdomains="false">192.168.1.13</domain>
        <domain includeSubdomains="false">192.168.1.14</domain>
        <domain includeSubdomains="false">192.168.1.15</domain>
        <domain includeSubdomains="false">192.168.1.20</domain>
        <domain includeSubdomains="false">192.168.1.30</domain>
        <domain includeSubdomains="false">192.168.1.50</domain>
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.1.101</domain>
        <domain includeSubdomains="false">192.168.1.102</domain>
        <domain includeSubdomains="false">192.168.1.200</domain>
        <domain includeSubdomains="false">192.168.1.253</domain>
        <domain includeSubdomains="false">192.168.1.254</domain>
        <!-- Red 192.168.0.x — alternativa habitual -->
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.0.10</domain>
        <domain includeSubdomains="false">192.168.0.11</domain>
        <domain includeSubdomains="false">192.168.0.12</domain>
        <domain includeSubdomains="false">192.168.0.100</domain>
        <!-- Red 10.0.0.x — algunos operadores -->
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.2</domain>
        <domain includeSubdomains="false">10.0.0.10</domain>
        <domain includeSubdomains="false">10.0.0.11</domain>
        <domain includeSubdomains="false">10.0.0.12</domain>
        <!-- Red 10.0.2.x — emulador Android -->
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
